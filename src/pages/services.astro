---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';
import { siteConfig } from '../data/siteConfig';
---

<BaseLayout
  title="Our Services"
  description="AI solutions, cloud engineering, MLOps, and data platforms. InQubyte delivers end-to-end AI and cloud services for modern enterprises."
>
  <Hero
    title="Our Services"
    subtitle="End-to-end AI and cloud solutions — from proof-of-concept to production at scale"
    compact
  />

  <!-- Services Grid -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {siteConfig.services.map((service, i) => (
          <div class="fade-in-up" style={`transition-delay: ${i * 100}ms`}>
            <ServiceCard
              icon={service.icon}
              title={service.title}
              description={service.description}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Process -->
  <section class="py-20 lg:py-28 bg-bg-secondary/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <SectionHeading
          title="How We Deliver"
          subtitle="A battle-tested process from AI discovery to production deployment"
        />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {siteConfig.processSteps.map((step, i) => (
          <div class="fade-in-up relative" style={`transition-delay: ${i * 100}ms`}>
            <div class="text-center">
              <div class="text-5xl font-extrabold text-accent/20 mb-4 font-mono">{step.step}</div>
              <h3 class="text-xl font-semibold text-text-primary mb-3">{step.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{step.description}</p>
            </div>
            {i < siteConfig.processSteps.length - 1 && (
              <div class="hidden lg:block absolute top-10 right-0 translate-x-1/2 text-accent/30">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <SectionHeading
          title="Technologies We Use"
          subtitle="Best-in-class tools across AI, cloud, and data engineering"
        />
      </div>
      <div class="flex flex-wrap justify-center gap-4 fade-in-up">
        {siteConfig.techStack.map((tech) => (
          <span class="px-5 py-2.5 text-sm font-mono font-medium text-text-secondary border border-white/10 rounded-lg hover:border-accent/40 hover:text-accent transition-all duration-200">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="py-20 lg:py-28 bg-bg-secondary/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <SectionHeading
          title="Industries We Serve"
          subtitle="AI and cloud solutions tailored to domain-specific challenges"
        />
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 lg:gap-6">
        {['Fintech & Banking', 'Healthcare & Biotech', 'E-Commerce', 'SaaS & Startups', 'Autonomous Vehicles', 'Cybersecurity', 'Energy & Climate', 'Media & AdTech', 'Manufacturing & IoT', 'Defense & Gov'].map((industry, i) => (
          <div class="fade-in-up glass text-center py-5 px-4 hover:border-accent/30 transition-colors duration-200" style={`transition-delay: ${i * 50}ms`}>
            <span class="text-sm font-medium text-text-secondary">{industry}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Let's Build Intelligence Into Your Business"
    description="Tell us about your AI and cloud challenges — we'll design the solution."
    buttonText="Get in Touch"
    buttonLink="/contact/"
  />
</BaseLayout>
