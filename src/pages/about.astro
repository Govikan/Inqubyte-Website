---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';

import CTABanner from '../components/CTABanner.astro';
import { siteConfig } from '../data/siteConfig';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="About Us"
  description="InQubyte is a team of AI researchers, cloud architects, and engineers on a mission to make intelligent technology accessible to every business."
>
  <Hero
    title="About InQubyte"
    subtitle="AI researchers, cloud architects, and engineers building the intelligent systems of tomorrow"
    compact
  />

  <!-- Mission -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="fade-in-up">
          <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-6">Our Mission</h2>
          <div class="h-1 w-16 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary text-lg leading-relaxed mb-6">
            To democratize AI and cloud technology for businesses of every size. We believe the most powerful AI isn't locked in research labs — it's deployed in production, solving real problems, and driving measurable outcomes.
          </p>
          <p class="text-text-secondary text-lg leading-relaxed">
            Founded by engineers from leading AI and cloud companies, InQubyte combines deep research expertise with battle-tested production engineering. We bridge the gap between cutting-edge AI and reliable, scalable systems.
          </p>
        </div>
        <div class="fade-in-up" style="transition-delay: 200ms">
          <div class="glass p-8 lg:p-10">
            <blockquote class="text-xl font-medium text-text-primary italic leading-relaxed">
              "The best AI is invisible — it just makes everything work smarter."
            </blockquote>
            <div class="mt-4 text-text-secondary text-sm">— InQubyte Founding Principle</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 lg:py-28 bg-bg-secondary/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <SectionHeading
          title="Our Values"
          subtitle="The principles that guide how we build AI and cloud solutions"
        />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {siteConfig.values.map((value, i) => (
          <div class="fade-in-up glass p-6 text-center" style={`transition-delay: ${i * 100}ms`}>
            <div class="text-4xl mb-4">{value.icon}</div>
            <h3 class="text-lg font-semibold text-text-primary mb-3">{value.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="fade-in-up">
        <SectionHeading
          title="Why Choose InQubyte"
          subtitle="What sets us apart in the AI and cloud landscape"
        />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        <div class="fade-in-up glass p-6 lg:p-8 flex gap-5" style="transition-delay: 0ms">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-accent/15 text-accent flex items-center justify-center text-xl">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Startup Speed, Enterprise Quality</h3>
            <p class="text-text-secondary text-sm leading-relaxed">We move fast without cutting corners. Rapid prototyping, agile delivery, and production-grade code from day one.</p>
          </div>
        </div>
        <div class="fade-in-up glass p-6 lg:p-8 flex gap-5" style="transition-delay: 100ms">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-accent/15 text-accent flex items-center justify-center text-xl">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">End-to-End AI + Cloud</h3>
            <p class="text-text-secondary text-sm leading-relaxed">From model training to cloud deployment, we own the full stack. No handoffs, no gaps, no finger-pointing between vendors.</p>
          </div>
        </div>
        <div class="fade-in-up glass p-6 lg:p-8 flex gap-5" style="transition-delay: 200ms">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-accent/15 text-accent flex items-center justify-center text-xl">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Security & Compliance Built In</h3>
            <p class="text-text-secondary text-sm leading-relaxed">Zero-trust architectures, SOC2 and HIPAA compliance, and DevSecOps practices are standard — not add-ons.</p>
          </div>
        </div>
        <div class="fade-in-up glass p-6 lg:p-8 flex gap-5" style="transition-delay: 300ms">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-accent/15 text-accent flex items-center justify-center text-xl">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-text-primary mb-2">Your Extended Team</h3>
            <p class="text-text-secondary text-sm leading-relaxed">We embed with your team, not around it. Knowledge transfer, documentation, and upskilling are part of every engagement.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 border-y border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
        {siteConfig.stats.map((stat, i) => (
          <div class="text-center fade-in-up" style={`transition-delay: ${i * 100}ms`}>
            <div class="text-3xl md:text-4xl font-extrabold gradient-text">{stat.value}</div>
            <div class="text-text-secondary text-sm mt-2">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Join Our Mission"
    description="Whether you're looking to build with us or work alongside us — let's connect."
    buttonText="Get in Touch"
    buttonLink={`${base}contact/`}
  />
</BaseLayout>
