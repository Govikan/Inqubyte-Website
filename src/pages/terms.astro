---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { siteConfig } from '../data/siteConfig';
const base = import.meta.env.BASE_URL;
const lastUpdated = 'March 21, 2026';
---

<BaseLayout
  title="Terms of Use"
  description="InQubyte's terms of use outline the rules, guidelines, and legal agreements governing your use of our website and services."
>
  <Hero
    title="Terms of Use"
    subtitle={`Last updated: ${lastUpdated}`}
    compact
  />

  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose prose-invert prose-lg max-w-none space-y-12">

        <!-- Acceptance -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">1. Acceptance of Terms</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed">
            By accessing and using the InQubyte website at <a href={siteConfig.url} class="text-accent hover:text-accent-secondary transition-colors">{siteConfig.url}</a> ("Website") and any services provided by InQubyte ("Services"), you agree to be bound by these Terms of Use ("Terms"). If you do not agree to these Terms, please do not use our Website or Services. We reserve the right to modify these Terms at any time, and your continued use of the Website constitutes acceptance of any changes.
          </p>
        </div>

        <!-- Description of Services -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">2. Description of Services</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed">
            InQubyte provides artificial intelligence, cloud computing, data engineering, and technology consulting services. Our Website provides information about our services, team, and capabilities. Specific service engagements are governed by separate service agreements or statements of work between InQubyte and the client.
          </p>
        </div>

        <!-- User Responsibilities -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">3. User Responsibilities</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed mb-4">By using our Website, you agree to:</p>
          <ul class="space-y-2 text-text-secondary">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span>Use the Website only for lawful purposes and in accordance with these Terms</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span>Provide accurate and truthful information when submitting forms or contacting us</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span>Not attempt to interfere with or disrupt the Website's functionality, security, or infrastructure</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span>Not engage in unauthorized data collection, scraping, or automated access to the Website</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span>Not transmit any malicious code, viruses, or harmful content through the Website</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span>Not impersonate any person or entity, or falsely represent your affiliation with any person or entity</span>
            </li>
          </ul>
        </div>

        <!-- Intellectual Property -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">4. Intellectual Property</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed mb-4">
            All content on this Website — including but not limited to text, graphics, logos, icons, images, software, code, and design — is the property of InQubyte or its licensors and is protected by applicable intellectual property laws.
          </p>
          <div class="grid sm:grid-cols-2 gap-4 mt-4">
            <div class="bg-white/5 border border-white/10 rounded-xl p-5">
              <h4 class="text-text-primary font-semibold mb-2">You May</h4>
              <p class="text-text-secondary text-sm">View and access the Website for personal, non-commercial informational purposes.</p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-5">
              <h4 class="text-text-primary font-semibold mb-2">You May Not</h4>
              <p class="text-text-secondary text-sm">Copy, reproduce, distribute, modify, create derivative works, publicly display, or commercially exploit any content without prior written consent from InQubyte.</p>
            </div>
          </div>
        </div>

        <!-- Confidentiality -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">5. Confidentiality</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed">
            Any confidential information shared between InQubyte and its clients during service engagements is subject to confidentiality obligations as defined in the applicable service agreement. Information submitted through our Website contact forms will be treated in accordance with our <a href={`${base}privacy/`} class="text-accent hover:text-accent-secondary transition-colors">Privacy Policy</a>.
          </p>
        </div>

        <!-- Disclaimers -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">6. Disclaimers</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed mb-4">
            The Website and its content are provided on an <strong class="text-text-primary">"as is"</strong> and <strong class="text-text-primary">"as available"</strong> basis without warranties of any kind, either express or implied. InQubyte disclaims all warranties, including but not limited to:
          </p>
          <ul class="space-y-2 text-text-secondary">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span>Implied warranties of merchantability, fitness for a particular purpose, and non-infringement</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span>That the Website will be uninterrupted, error-free, or free of viruses or other harmful components</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span>The accuracy, reliability, or completeness of any content or information on the Website</span>
            </li>
          </ul>
        </div>

        <!-- Limitation of Liability -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">7. Limitation of Liability</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed">
            To the fullest extent permitted by applicable law, InQubyte and its officers, directors, employees, agents, and affiliates shall not be liable for any indirect, incidental, special, consequential, or punitive damages — including but not limited to loss of profits, data, use, or goodwill — arising out of or in connection with your access to or use of (or inability to use) the Website or Services, whether based on warranty, contract, tort, or any other legal theory, even if InQubyte has been advised of the possibility of such damages.
          </p>
        </div>

        <!-- Indemnification -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">8. Indemnification</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed">
            You agree to indemnify, defend, and hold harmless InQubyte and its officers, directors, employees, and agents from and against any and all claims, liabilities, damages, losses, costs, and expenses (including reasonable attorneys' fees) arising from your use of the Website, your violation of these Terms, or your violation of any rights of a third party.
          </p>
        </div>

        <!-- Third-Party Links -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">9. Third-Party Links</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed">
            Our Website may contain links to third-party websites or services that are not owned or controlled by InQubyte. We have no control over, and assume no responsibility for, the content, privacy policies, or practices of any third-party websites. You acknowledge and agree that InQubyte shall not be responsible or liable for any damage or loss caused by the use of any such third-party content, goods, or services.
          </p>
        </div>

        <!-- Governing Law -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">10. Governing Law</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed">
            These Terms shall be governed by and construed in accordance with the laws of the State of Washington, United States, without regard to its conflict of law provisions. Any disputes arising out of or relating to these Terms or your use of the Website shall be resolved exclusively in the state or federal courts located in King County, Washington.
          </p>
        </div>

        <!-- Termination -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">11. Termination</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed">
            We reserve the right to terminate or suspend your access to the Website at our sole discretion, without notice, for conduct that we believe violates these Terms, is harmful to other users, or is otherwise objectionable. All provisions of these Terms that by their nature should survive termination shall survive, including intellectual property provisions, disclaimers, indemnification, and limitations of liability.
          </p>
        </div>

        <!-- Severability -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">12. Severability</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed">
            If any provision of these Terms is found to be unenforceable or invalid by a court of competent jurisdiction, that provision shall be limited or eliminated to the minimum extent necessary, and the remaining provisions of these Terms shall remain in full force and effect.
          </p>
        </div>

        <!-- Contact -->
        <div class="fade-in-up">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">13. Contact Us</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed mb-4">
            If you have any questions about these Terms of Use, please contact us:
          </p>
          <div class="bg-white/5 border border-white/10 rounded-xl p-6">
            <p class="text-text-primary font-semibold text-lg mb-3">{siteConfig.name}</p>
            <ul class="space-y-2 text-text-secondary text-sm">
              <li class="flex items-center gap-3">
                <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                <a href={`mailto:${siteConfig.email}`} class="text-accent hover:text-accent-secondary transition-colors">{siteConfig.email}</a>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-4 h-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span>{siteConfig.address}</span>
              </li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>
</BaseLayout>
