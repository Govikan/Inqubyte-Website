---
import { siteConfig } from '../data/siteConfig';
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href={base} class="flex items-center group">
        <img
          src={`${base}logo-dark.png`}
          alt={siteConfig.name}
          class="h-10 lg:h-12 w-auto"
          loading="eager"
        />
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {siteConfig.navLinks.map((link) => {
          const fullHref = `${base}${link.href}`;
          return (
            <a
              href={fullHref}
              class:list={[
                'text-sm font-medium transition-colors duration-200 hover:text-accent',
                currentPath === fullHref || (link.href !== '' && currentPath.startsWith(fullHref))
                  ? 'text-accent'
                  : 'text-text-secondary',
              ]}
            >
              {link.label}
            </a>
          );
        })}
        <a
          href={`${base}contact/`}
          class="bg-accent hover:bg-accent/80 text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-accent/25"
        >
          Get a Quote
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-text-primary p-2"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden glass-strong rounded-xl mb-4 overflow-hidden">
      <div class="px-4 py-6 space-y-4">
        {siteConfig.navLinks.map((link) => {
          const fullHref = `${base}${link.href}`;
          return (
            <a
              href={fullHref}
              class:list={[
                'block text-base font-medium transition-colors duration-200 hover:text-accent',
                currentPath === fullHref || (link.href !== '' && currentPath.startsWith(fullHref))
                  ? 'text-accent'
                  : 'text-text-secondary',
              ]}
            >
              {link.label}
            </a>
          );
        })}
        <a
          href={`${base}contact/`}
          class="block text-center bg-accent hover:bg-accent/80 text-white font-semibold px-5 py-2.5 rounded-lg transition-colors duration-200 mt-4"
        >
          Get a Quote
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Navbar background on scroll
  const navbar = document.getElementById('navbar');
  const handleScroll = () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-bg-primary/80', 'backdrop-blur-lg', 'shadow-lg', 'shadow-black/10');
    } else {
      navbar?.classList.remove('bg-bg-primary/80', 'backdrop-blur-lg', 'shadow-lg', 'shadow-black/10');
    }
  };
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();
</script>
