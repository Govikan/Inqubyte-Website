---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import { siteConfig } from '../data/siteConfig';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Toastmasters Zoom App Guide"
  description="Complete guide to installing, using, and removing the Toastmasters Meeting Manager Zoom App. Manage roles, timers, ah-counts, grammarian notes, table topics, and voting — all inside Zoom."
>
  <Hero
    title="Toastmasters Zoom App"
    subtitle="Complete guide to adding, using, and removing the app"
    compact
  />

  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Table of Contents -->
      <div class="fade-in-up bg-white/5 border border-white/10 rounded-2xl p-6 md:p-8 mb-16">
        <h2 class="text-xl font-bold text-text-primary mb-4">Table of Contents</h2>
        <nav>
          <ol class="space-y-2 text-sm">
            <li><a href="#overview" class="text-accent hover:text-accent-secondary transition-colors">1. Overview</a></li>
            <li><a href="#adding-the-app" class="text-accent hover:text-accent-secondary transition-colors">2. Adding the App to Zoom</a></li>
            <li><a href="#getting-started" class="text-accent hover:text-accent-secondary transition-colors">3. Getting Started</a></li>
            <li><a href="#meeting-setup" class="text-accent hover:text-accent-secondary transition-colors">4. Meeting Setup Phase</a></li>
            <li><a href="#using-the-app" class="text-accent hover:text-accent-secondary transition-colors">5. Using the App During Meetings</a></li>
            <li class="pl-4"><a href="#timer" class="text-text-secondary hover:text-accent transition-colors">5.1 Speech Timer</a></li>
            <li class="pl-4"><a href="#agenda" class="text-text-secondary hover:text-accent transition-colors">5.2 Agenda Management</a></li>
            <li class="pl-4"><a href="#ah-counter" class="text-text-secondary hover:text-accent transition-colors">5.3 Ah-Counter</a></li>
            <li class="pl-4"><a href="#grammarian" class="text-text-secondary hover:text-accent transition-colors">5.4 Grammarian Tools</a></li>
            <li class="pl-4"><a href="#table-topics" class="text-text-secondary hover:text-accent transition-colors">5.5 Table Topics</a></li>
            <li class="pl-4"><a href="#voting" class="text-text-secondary hover:text-accent transition-colors">5.6 Voting</a></li>
            <li class="pl-4"><a href="#report" class="text-text-secondary hover:text-accent transition-colors">5.7 Meeting Report</a></li>
            <li><a href="#host-vs-guest" class="text-accent hover:text-accent-secondary transition-colors">6. Host vs Guest Permissions</a></li>
            <li><a href="#removing-the-app" class="text-accent hover:text-accent-secondary transition-colors">7. Removing the App</a></li>
            <li><a href="#troubleshooting" class="text-accent hover:text-accent-secondary transition-colors">8. Troubleshooting</a></li>
            <li><a href="#support" class="text-accent hover:text-accent-secondary transition-colors">9. Support</a></li>
          </ol>
        </nav>
      </div>

      <div class="space-y-16">

        <!-- 1. Overview -->
        <div id="overview" class="fade-in-up scroll-mt-24">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">1. Overview</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed mb-6">
            The <strong class="text-text-primary">Toastmasters Meeting Manager</strong> is a Zoom App that runs directly inside the Zoom meeting sidebar. It provides everything you need to run a complete Toastmasters meeting digitally — no switching between apps or browser tabs.
          </p>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
              <div class="text-2xl mb-2">&#9201;</div>
              <h4 class="text-text-primary font-semibold text-sm">Speech Timer</h4>
              <p class="text-text-secondary text-xs mt-1">Color-coded timing with presets</p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
              <div class="text-2xl mb-2">&#128221;</div>
              <h4 class="text-text-primary font-semibold text-sm">Role Manager</h4>
              <p class="text-text-secondary text-xs mt-1">Assign 12 meeting roles</p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
              <div class="text-2xl mb-2">&#128483;</div>
              <h4 class="text-text-primary font-semibold text-sm">Ah-Counter</h4>
              <p class="text-text-secondary text-xs mt-1">Track 8 filler word types</p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
              <div class="text-2xl mb-2">&#128214;</div>
              <h4 class="text-text-primary font-semibold text-sm">Grammarian</h4>
              <p class="text-text-secondary text-xs mt-1">Word of the day & notes</p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
              <div class="text-2xl mb-2">&#127922;</div>
              <h4 class="text-text-primary font-semibold text-sm">Table Topics</h4>
              <p class="text-text-secondary text-xs mt-1">Random topic generator</p>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
              <div class="text-2xl mb-2">&#9989;</div>
              <h4 class="text-text-primary font-semibold text-sm">Voting & Reports</h4>
              <p class="text-text-secondary text-xs mt-1">Vote & generate summaries</p>
            </div>
          </div>
        </div>

        <!-- 2. Adding the App -->
        <div id="adding-the-app" class="fade-in-up scroll-mt-24">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">2. Adding the App to Zoom</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>

          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent/20 text-accent flex items-center justify-center font-bold text-sm">1</div>
              <div>
                <h4 class="text-text-primary font-semibold mb-1">Open the Zoom Marketplace</h4>
                <p class="text-text-secondary text-sm leading-relaxed">
                  Go to the <a href="https://marketplace.zoom.us/" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-secondary transition-colors">Zoom App Marketplace</a> or search for <strong class="text-text-primary">"Toastmasters"</strong> directly within the Zoom desktop client under the <strong class="text-text-primary">Apps</strong> tab.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent/20 text-accent flex items-center justify-center font-bold text-sm">2</div>
              <div>
                <h4 class="text-text-primary font-semibold mb-1">Click "Add" or "Install"</h4>
                <p class="text-text-secondary text-sm leading-relaxed">
                  Click the <strong class="text-text-primary">Add</strong> button on the app listing page. You will be prompted to authorize the app with your Zoom account.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent/20 text-accent flex items-center justify-center font-bold text-sm">3</div>
              <div>
                <h4 class="text-text-primary font-semibold mb-1">Authorize the App</h4>
                <p class="text-text-secondary text-sm leading-relaxed">
                  Review the permissions requested and click <strong class="text-text-primary">Authorize</strong>. The app requires access to your meeting context (participant names, meeting ID) to function properly. We do not store any personal data beyond the active meeting session.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-accent/20 text-accent flex items-center justify-center font-bold text-sm">4</div>
              <div>
                <h4 class="text-text-primary font-semibold mb-1">App is Ready</h4>
                <p class="text-text-secondary text-sm leading-relaxed">
                  Once authorized, the app will appear in your Zoom sidebar under <strong class="text-text-primary">Apps</strong>. You can open it during any Zoom meeting.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- 3. Getting Started -->
        <div id="getting-started" class="fade-in-up scroll-mt-24">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">3. Getting Started</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed mb-4">
            To launch the app during a Zoom meeting:
          </p>
          <ol class="space-y-3 text-text-secondary">
            <li class="flex items-start gap-3">
              <span class="text-accent font-bold mt-0.5">1.</span>
              <span>Join or start a Zoom meeting</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent font-bold mt-0.5">2.</span>
              <span>Click the <strong class="text-text-primary">Apps</strong> button in the Zoom toolbar (bottom of the meeting window)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent font-bold mt-0.5">3.</span>
              <span>Select <strong class="text-text-primary">Toastmasters</strong> from your installed apps</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent font-bold mt-0.5">4.</span>
              <span>The app opens in the Zoom sidebar with the <strong class="text-text-primary">Meeting Setup</strong> screen</span>
            </li>
          </ol>
          <div class="bg-accent/10 border border-accent/30 rounded-xl p-4 mt-6">
            <p class="text-text-secondary text-sm">
              <strong class="text-accent">Note:</strong> The meeting host has full control over the app. Guests can view the meeting state in real-time but cannot modify roles, timer, or settings.
            </p>
          </div>
        </div>

        <!-- 4. Meeting Setup Phase -->
        <div id="meeting-setup" class="fade-in-up scroll-mt-24">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">4. Meeting Setup Phase</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed mb-6">
            When the app launches, you enter the <strong class="text-text-primary">Setup Phase</strong>. Here the host assigns roles and reviews the agenda before the meeting begins.
          </p>

          <h3 class="text-xl font-semibold text-text-primary mt-8 mb-4">Assigning Roles</h3>
          <p class="text-text-secondary leading-relaxed mb-4">
            The host can assign up to <strong class="text-text-primary">12 Toastmasters roles</strong> from the dropdown menus. Participants in the meeting appear in the dropdown list automatically.
          </p>
          <div class="grid sm:grid-cols-2 gap-3 mb-6">
            {[
              'Toastmaster of the Day', 'Timer', 'Grammarian', 'Ah-Counter',
              'Table Topics Master', 'General Evaluator',
              'Speaker 1', 'Speaker 2', 'Speaker 3',
              'Evaluator 1', 'Evaluator 2', 'Evaluator 3'
            ].map((role) => (
              <div class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-text-secondary text-sm">
                {role}
              </div>
            ))}
          </div>

          <h3 class="text-xl font-semibold text-text-primary mt-8 mb-4">Reviewing the Agenda</h3>
          <p class="text-text-secondary leading-relaxed mb-4">
            A default agenda with 16 items is provided. The host can:
          </p>
          <ul class="space-y-2 text-text-secondary">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Add</strong> new agenda items</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Edit</strong> item names and durations</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Remove</strong> items not needed</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Reorder</strong> items by dragging</span>
            </li>
          </ul>
          <p class="text-text-secondary leading-relaxed mt-4">
            Once everything is set, click the green <strong class="text-text-primary">"Start Meeting"</strong> button to transition to the running phase.
          </p>
        </div>

        <!-- 5. Using the App -->
        <div id="using-the-app" class="fade-in-up scroll-mt-24">
          <h2 class="text-2xl md:text-3xl font-bold text-text-primary mb-4">5. Using the App During Meetings</h2>
          <div class="h-1 w-12 rounded-full bg-gradient-to-r from-accent to-accent-tertiary mb-6"></div>
          <p class="text-text-secondary leading-relaxed mb-6">
            Once the meeting starts, the app switches to the <strong class="text-text-primary">Meeting Dashboard</strong> with 7 tabs for different functions. All participants see the same real-time state.
          </p>
        </div>

        <!-- 5.1 Timer -->
        <div id="timer" class="fade-in-up scroll-mt-24">
          <h3 class="text-xl font-semibold text-text-primary mb-4">5.1 Speech Timer</h3>
          <p class="text-text-secondary leading-relaxed mb-4">
            The Timer tab provides a professional color-coded speech timer with three presets:
          </p>
          <div class="grid sm:grid-cols-3 gap-4 mb-6">
            <div class="bg-white/5 border border-white/10 rounded-xl p-4">
              <h4 class="text-text-primary font-semibold text-sm mb-2">Prepared Speech</h4>
              <div class="space-y-1 text-xs text-text-secondary">
                <p><span class="inline-block w-3 h-3 rounded-full bg-green-500 mr-2 align-middle"></span>Green: 5:00</p>
                <p><span class="inline-block w-3 h-3 rounded-full bg-yellow-500 mr-2 align-middle"></span>Yellow: 6:00</p>
                <p><span class="inline-block w-3 h-3 rounded-full bg-red-500 mr-2 align-middle"></span>Red: 7:00</p>
              </div>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-4">
              <h4 class="text-text-primary font-semibold text-sm mb-2">Table Topics</h4>
              <div class="space-y-1 text-xs text-text-secondary">
                <p><span class="inline-block w-3 h-3 rounded-full bg-green-500 mr-2 align-middle"></span>Green: 1:00</p>
                <p><span class="inline-block w-3 h-3 rounded-full bg-yellow-500 mr-2 align-middle"></span>Yellow: 1:30</p>
                <p><span class="inline-block w-3 h-3 rounded-full bg-red-500 mr-2 align-middle"></span>Red: 2:00</p>
              </div>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-4">
              <h4 class="text-text-primary font-semibold text-sm mb-2">Evaluation</h4>
              <div class="space-y-1 text-xs text-text-secondary">
                <p><span class="inline-block w-3 h-3 rounded-full bg-green-500 mr-2 align-middle"></span>Green: 2:00</p>
                <p><span class="inline-block w-3 h-3 rounded-full bg-yellow-500 mr-2 align-middle"></span>Yellow: 2:30</p>
                <p><span class="inline-block w-3 h-3 rounded-full bg-red-500 mr-2 align-middle"></span>Red: 3:00</p>
              </div>
            </div>
          </div>
          <p class="text-text-secondary leading-relaxed mb-3"><strong class="text-text-primary">How to use:</strong></p>
          <ol class="space-y-2 text-text-secondary text-sm">
            <li class="flex items-start gap-3">
              <span class="text-accent font-bold mt-0.5">1.</span>
              <span>Select the <strong class="text-text-primary">speaker name</strong> from the participant dropdown</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent font-bold mt-0.5">2.</span>
              <span>Choose the <strong class="text-text-primary">timer type</strong> (Prepared Speech, Table Topics, or Evaluation)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent font-bold mt-0.5">3.</span>
              <span>Click <strong class="text-text-primary">Start</strong> to begin timing</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent font-bold mt-0.5">4.</span>
              <span>Click <strong class="text-text-primary">Stop</strong> when the speaker finishes &mdash; the timing is saved to history</span>
            </li>
          </ol>
          <p class="text-text-secondary text-sm mt-4">
            The timer display changes color as the speaker progresses through green, yellow, and red zones. Overtime is indicated with a pulsing red animation. All timing history is preserved with color-coded status tags (Over, Good, Under).
          </p>
        </div>

        <!-- 5.2 Agenda -->
        <div id="agenda" class="fade-in-up scroll-mt-24">
          <h3 class="text-xl font-semibold text-text-primary mb-4">5.2 Agenda Management</h3>
          <p class="text-text-secondary leading-relaxed">
            The Agenda tab displays all meeting items with assigned participants and estimated durations. During the meeting, the host can mark items as complete to track progress. Guests see the agenda in real-time as a read-only view.
          </p>
        </div>

        <!-- 5.3 Ah-Counter -->
        <div id="ah-counter" class="fade-in-up scroll-mt-24">
          <h3 class="text-xl font-semibold text-text-primary mb-4">5.3 Ah-Counter</h3>
          <p class="text-text-secondary leading-relaxed mb-4">
            The Ah-Counter tab tracks <strong class="text-text-primary">8 types of filler words</strong> for each participant:
          </p>
          <div class="flex flex-wrap gap-2 mb-4">
            {['Um', 'Uh', 'Ah', 'So', 'Like', 'You know', 'Basically', 'Right'].map((word) => (
              <span class="bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 text-text-secondary text-sm">
                {word}
              </span>
            ))}
          </div>
          <p class="text-text-secondary leading-relaxed text-sm">
            <strong class="text-text-primary">How to use:</strong> Select a participant from the dropdown, then tap the corresponding filler word button each time you hear it. The count increments automatically. A summary of all filler words per participant is available in the meeting report.
          </p>
        </div>

        <!-- 5.4 Grammarian -->
        <div id="grammarian" class="fade-in-up scroll-mt-24">
          <h3 class="text-xl font-semibold text-text-primary mb-4">5.4 Grammarian Tools</h3>
          <p class="text-text-secondary leading-relaxed mb-4">
            The Grammarian tab provides tools for the Word of the Day and language tracking:
          </p>
          <ul class="space-y-3 text-text-secondary text-sm">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Word of the Day:</strong> Click "Fetch Word of Day" to automatically fetch a word with its definition from online dictionaries. You can also enter a custom word.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Pronunciation:</strong> Click the speaker icon to hear the word pronounced using text-to-speech.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Usage Tracking:</strong> Select a participant and click "+ Usage" each time they use the word of the day in their speech.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Notes:</strong> Add grammar and language observations with good/bad indicators for the meeting report.</span>
            </li>
          </ul>
        </div>

        <!-- 5.5 Table Topics -->
        <div id="table-topics" class="fade-in-up scroll-mt-24">
          <h3 class="text-xl font-semibold text-text-primary mb-4">5.5 Table Topics</h3>
          <p class="text-text-secondary leading-relaxed mb-4">
            The Table Topics tab helps the Table Topics Master run impromptu speaking exercises:
          </p>
          <ul class="space-y-3 text-text-secondary text-sm">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Random Topic Generator:</strong> Click the button to randomly select from 78 pre-loaded topics. Previously used topics are excluded to avoid repetition.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Timer Integration:</strong> Start the Table Topics timer directly from this tab with the 1-2 minute preset.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Topic History:</strong> View all previously used topics in the current session.</span>
            </li>
          </ul>
        </div>

        <!-- 5.6 Voting -->
        <div id="voting" class="fade-in-up scroll-mt-24">
          <h3 class="text-xl font-semibold text-text-primary mb-4">5.6 Voting</h3>
          <p class="text-text-secondary leading-relaxed mb-4">
            The Voting tab enables participants to vote for the best performers in three categories:
          </p>
          <div class="grid sm:grid-cols-3 gap-4 mb-4">
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
              <div class="text-2xl mb-2">&#127942;</div>
              <h4 class="text-text-primary font-semibold text-sm">Best Speaker</h4>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
              <div class="text-2xl mb-2">&#11088;</div>
              <h4 class="text-text-primary font-semibold text-sm">Best Evaluator</h4>
            </div>
            <div class="bg-white/5 border border-white/10 rounded-xl p-4 text-center">
              <div class="text-2xl mb-2">&#128161;</div>
              <h4 class="text-text-primary font-semibold text-sm">Best Table Topics</h4>
            </div>
          </div>
          <p class="text-text-secondary text-sm leading-relaxed">
            <strong class="text-text-primary">How it works:</strong> The host opens voting by clicking "Open Voting." Participants can then cast their votes. Once everyone has voted, the host clicks "Close Voting" to finalize results. Winners are displayed in the meeting report.
          </p>
        </div>

        <!-- 5.7 Report -->
        <div id="report" class="fade-in-up scroll-mt-24">
          <h3 class="text-xl font-semibold text-text-primary mb-4">5.7 Meeting Report</h3>
          <p class="text-text-secondary leading-relaxed mb-4">
            The Report tab generates a comprehensive post-meeting summary that includes:
          </p>
          <ul class="space-y-2 text-text-secondary text-sm">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Speaker Timing Analysis</strong> &mdash; On-time, under, or over for each speaker</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Filler Word Statistics</strong> &mdash; Total filler words per participant</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Grammarian Notes</strong> &mdash; Word of the day, usage counts, and language observations</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-1.5">&#9679;</span>
              <span><strong class="text-text-primary">Voting Results</strong> &mdash; Winners for each category</span>
            </li>
          </ul>
