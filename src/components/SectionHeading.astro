---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { title, subtitle, align = 'center' } = Astro.props;
---

<div class:list={['mb-12 lg:mb-16', align === 'center' ? 'text-center' : 'text-left']}>
  <h2 class="text-3xl md:text-4xl font-bold text-text-primary">
    {title}
  </h2>
  <div class:list={['mt-3 h-1 w-16 rounded-full bg-gradient-to-r from-accent to-accent-tertiary', align === 'center' ? 'mx-auto' : '']}>
  </div>
  {subtitle && (
    <p class:list={['mt-4 text-text-secondary text-lg max-w-2xl', align === 'center' ? 'mx-auto' : '']}>
      {subtitle}
    </p>
  )}
</div>
