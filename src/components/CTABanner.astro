---
interface Props {
  heading: string;
  description: string;
  buttonText: string;
  buttonLink: string;
}

const { heading, description, buttonText, buttonLink } = Astro.props;
---

<section class="py-20 relative overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-accent/10 via-accent-secondary/10 to-accent-tertiary/10"></div>
  <div class="absolute inset-0 -z-10 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.1) 1px, transparent 1px); background-size: 40px 40px;"></div>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4">{heading}</h2>
    <p class="text-text-secondary text-lg mb-8 max-w-2xl mx-auto">{description}</p>
    <a
      href={buttonLink}
      class="inline-block bg-accent hover:bg-accent/80 text-white font-semibold px-8 py-3.5 rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-accent/25"
    >
      {buttonText}
    </a>
  </div>
</section>
