---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="glass card-hover p-6 lg:p-8 group">
  <div class="text-4xl mb-4">{icon}</div>
  <h3 class="text-xl font-semibold text-text-primary mb-3 group-hover:text-accent transition-colors duration-200">
    {title}
  </h3>
  <p class="text-text-secondary text-sm leading-relaxed">
    {description}
  </p>
</div>
